{
  "name": "Teams API MongoDB Dev Container",
  "dockerComposeFile": "./docker-compose.yml",
  "service": "app",
  "runServices": ["app", "db"],
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 27017],
  "postCreateCommand": "npm install && node --version && npm --version && mongosh --version"
}